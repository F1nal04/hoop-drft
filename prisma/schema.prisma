// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CurrentPlayer {
  id       Int    @id @default(autoincrement())
  name     String
  position String
  team     String
  ppg      Float
  rpg      Float
  apg      Float
  bpg      Float
  rank     Int    @unique

  @@map("current_players")
}

model HistoricalPlayer {
  id       Int    @id @default(autoincrement())
  name     String
  position String
  team     String
  ppg      Float
  rpg      Float
  apg      Float
  bpg      Float
  rank     Int    @unique

  @@map("historical_players")
}
